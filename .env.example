# WeChat Bot Token (auto-populated after QR login)
# WECHAT_BOT_TOKEN=

# WeChat API base URL (default: https://ilinkai.weixin.qq.com)
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com

# Claude model: opus, sonnet, haiku (default: sonnet)
# CLAUDE_MODEL=sonnet

# Custom system prompt for Claude
# CLAUDE_SYSTEM_PROMPT=

# Max budget per query in USD (default: 1.0)
# CLAUDE_MAX_BUDGET=1.0

# Permission mode: default, auto (default: default)
# CLAUDE_PERMISSION_MODE=default

# Allowed tools (comma-separated, default: all)
# CLAUDE_ALLOWED_TOOLS=

# Query timeout in ms (default: 300000 = 5 min)
# CLAUDE_TIMEOUT_MS=300000

# Max concurrent Claude processes (default: 3)
# CLAUDE_MAX_CONCURRENT=3

# Max characters per WeChat message (default: 4000)
# WECHAT_MAX_MSG_LENGTH=4000

# State directory (default: ./data)
# STATE_DIR=./data

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
